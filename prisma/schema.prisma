generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Account {
  id     String      @id @default(cuid())
  name   String
  type   AccountType
  active    Boolean     @default(true)
  balance   Decimal     @default(0) @db.Decimal(12, 2)
  isDefault Boolean     @default(false)

  transactions         Transaction[] @relation("AccountTransactions")
}

model Category {
  id       String        @id @default(cuid())
  name     String        @unique
  type     CategoryType
  concepts Concept[]
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Concept {
  id              String        @id @default(cuid())
  name            String
  categoryId      String
  recurring       Boolean       @default(false)
  recurringMonths Int[]
  paymentUrl      String?
  dueDateNote     String?
  active          Boolean       @default(true)
  category        Category      @relation(fields: [categoryId], references: [id])
  transactions    Transaction[]
  recurringCompletions RecurringCompletion[]

  @@unique([name, categoryId])
}

model RecurringCompletion {
  id        String  @id @default(cuid())
  conceptId String
  year      Int
  month     Int
  concept   Concept @relation(fields: [conceptId], references: [id])

  @@unique([conceptId, year, month])
}

model Transaction {
  id          String          @id @default(cuid())
  date        DateTime
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?

  conceptId   String?
  concept     Concept?        @relation(fields: [conceptId], references: [id])

  accountId   String?
  account     Account?        @relation("AccountTransactions", fields: [accountId], references: [id])

  transferId  String?

  createdAt   DateTime        @default(now())
}

enum AccountType {
  CASH
  BANK
  CARD
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  ADJUSTMENT
}

// Etapa 1 del dictado de gastos: guarda frases en lenguaje natural tal cual
// las dicta/escribe el usuario, para juntar ejemplos reales con los que luego
// diseñar el parseo con IA (Etapa 2). Todavía no se convierten en Transaction.
model ExpenseDictation {
  id        String   @id @default(cuid())
  text      String
  userAgent String?
  createdAt DateTime @default(now())
}
